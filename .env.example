# Port the MCP server listens on
PORT=3100

# Public URL where this MCP server is reachable (used for OAuth resource metadata)
RESOURCE_URL=http://localhost:3100

# OAuth issuer URL (Better Auth endpoint on the Universal Goods server)
AUTH_ISSUER=http://localhost:4060/api/auth

# OAuth authorization server URL. Defaults to AUTH_ISSUER if unset.
AUTH_SERVER=http://localhost:4060/api/auth

# Base URL of the Universal Goods API that tools call on behalf of the user
UG_API_URL=http://localhost:4060

# ─── Session Cookie Auth (for CLI usage without browser OAuth) ────────────────
# Get from Chrome DevTools: Application → Cookies → app.universalgoods.xyz
# Copy the FULL cookie string (e.g. better-auth.session_token=abc123.sig456)
UG_SESSION_COOKIE=
UG_ORG_ID=
